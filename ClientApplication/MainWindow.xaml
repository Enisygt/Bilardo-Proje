<Window x:Class="ClientApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Müşteri Ekranı" 
        WindowStyle="None" 
        Topmost="True" 
        WindowState="Maximized"
        Background="#1E1E1E" Foreground="White">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid>
        <!-- Lock Screen for Invalid IP -->
        <Border Background="Red" Visibility="{Binding IsInvalidIp, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="100">
            <TextBlock Text="{Binding InvalidIpMessage}" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
        </Border>

        <!-- Main UI -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Left side: Status and Button -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding KalanSureText, FallbackValue='Süre: 00:00'}" FontSize="48" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,30" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ToplamTutar, StringFormat='Toplam Tutar: ₺ {0:N2}', FallbackValue='Toplam Tutar: ₺ 0.00'}" FontSize="36" Margin="0,0,0,50" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Right side: Menu -->
            <Border Grid.Column="1" Background="#2D2D30" BorderBrush="Gray" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="MENÜ" FontSize="28" FontWeight="Bold" Foreground="White" Margin="20" HorizontalAlignment="Center"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
                        <ItemsControl ItemsSource="{Binding MenuItems}">
                            <!-- Item template for products -->
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Ad}" Command="{Binding DataContext.SiparisEkleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Margin="5" Height="60" FontSize="18" Background="#3E3E42" Foreground="White" BorderThickness="0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Admin Exit Password Panel (Hidden by default) -->
        <Border Background="#80000000" Visibility="{Binding IsAdminPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="200">
            <Border Background="White" Width="300" Height="200" CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Margin="20">
                    <TextBlock Text="Admin Çıkış" FontSize="20" FontWeight="Bold" Foreground="Black" Margin="0,0,0,20"/>
                    <PasswordBox x:Name="txtAdminPassword" PasswordChanged="txtAdminPassword_PasswordChanged" Margin="0,0,0,20" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Çıkış Yap" Command="{Binding ExitAppCommand}" Width="100" Height="30" Margin="0,0,10,0"/>
                        <Button Content="İptal" Command="{Binding CancelAdminPanelCommand}" Width="100" Height="30"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
