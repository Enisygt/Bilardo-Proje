<Window x:Class="ServerApplication.Views.Common.RoleSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kurulum: Rol Seçimi" Height="350" Width="500" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
            <TextBlock Text="Cihazın Rolünü Seçin" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30" />
            
            <Button x:Name="btnMaster" Content="Ben Ana Makineyim (Kasa / Server)" FontSize="18" Padding="10" Margin="0,0,0,15" Background="#4CAF50" Foreground="White" Click="BtnMaster_Click" />
            
            <Button x:Name="btnNode" Content="Ben Masa Terminaliyim (Client)" FontSize="18" Padding="10" Margin="0,0,0,15" Background="#2196F3" Foreground="White" Click="BtnNode_Click" />
            
            <StackPanel x:Name="pnlIpEntry" Visibility="Collapsed" Margin="0,15,0,0">
                <TextBlock Text="Ana Makinenin IP Adresini Girin (Örn: 192.168.1.100):" Margin="0,0,0,5" />
                <TextBox x:Name="txtMasterIp" FontSize="16" Padding="5" />
                <Button Content="Kaydet ve Başlat" FontSize="16" Padding="5" Margin="0,10,0,0" Click="BtnSaveNode_Click" Background="#FF9800" Foreground="White" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
