<Window x:Class="ServerApplication.Views.Common.AdminPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙ Yönetici Paneli" Height="600" Width="700" 
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Window.Resources>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A2A4A"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Uyarı Bildirimi (Overlay) -->
        <Border x:Name="NotificationBorder" Panel.ZIndex="100" HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                Background="#2E7D32" CornerRadius="12" Padding="20,12" Margin="0,0,0,30" Visibility="Collapsed"
                Opacity="0">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.5" ShadowDepth="4"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✅ " FontSize="20" VerticalAlignment="Center"/>
                <TextBlock Text="Değişiklikler kaydedildi!" 
                           Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        <!-- Şifre Girişi -->
        <StackPanel x:Name="pnlPassword" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🔒 Yönetici Şifresi" FontSize="20" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <PasswordBox x:Name="txtAdminPass" Width="200" FontSize="16" Padding="8,6"
                         Background="#2A2A4A" Foreground="White" BorderBrush="#444466"/>
            <Button Content="Giriş" Style="{StaticResource DarkBtn}" Width="120" Margin="0,12,0,0"
                    Background="#2E7D32" Click="BtnLogin_Click"/>
        </StackPanel>

        <!-- Ana Panel -->
        <TabControl x:Name="tabPanel" Visibility="Collapsed" Background="#1A1A2E" 
                    BorderBrush="#333355" Foreground="White" Margin="16">
            
            <!-- KAMPANYALAR TAB -->
            <TabItem Header="🎯 Kampanyalar">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView x:Name="lstKampanyalar" Grid.Row="0" Background="#2A2A4A" 
                              Foreground="White" BorderThickness="0" Margin="0,0,0,12">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Başlık" Width="150" DisplayMemberBinding="{Binding Baslik}"/>
                                <GridViewColumn Header="Açıklama" Width="200" DisplayMemberBinding="{Binding Aciklama}"/>
                                <GridViewColumn Header="Fiyat" Width="80" DisplayMemberBinding="{Binding Fiyat, StringFormat='₺{0:N0}'}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="txtKampanyaBaslik" Style="{StaticResource DarkTextBox}" 
                                 Width="150" Tag="Başlık"/>
                        <TextBox x:Name="txtKampanyaAciklama" Style="{StaticResource DarkTextBox}" 
                                 Width="200" Margin="8,0,0,0" Tag="Açıklama"/>
                        <TextBox x:Name="txtKampanyaFiyat" Style="{StaticResource DarkTextBox}" 
                                 Width="80" Margin="8,0,0,0" Tag="Fiyat"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="➕ Ekle" Style="{StaticResource DarkBtn}" Background="#2E7D32" Click="BtnKampanyaEkle_Click"/>
                        <Button Content="🗑 Sil" Style="{StaticResource DarkBtn}" Background="#C62828" Click="BtnKampanyaSil_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- MENÜ TAB -->
            <TabItem Header="📋 Menü Ürünleri">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView x:Name="lstUrunler" Grid.Row="0" Background="#2A2A4A" 
                              Foreground="White" BorderThickness="0" Margin="0,0,0,12">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Ürün Adı" Width="150" DisplayMemberBinding="{Binding Ad}"/>
                                <GridViewColumn Header="Fiyat" Width="80" DisplayMemberBinding="{Binding Fiyat, StringFormat='₺{0:N0}'}"/>
                                <GridViewColumn Header="Kategori" Width="120" DisplayMemberBinding="{Binding Kategori}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="txtUrunAd" Style="{StaticResource DarkTextBox}" Width="150" Tag="Ürün Adı"/>
                        <TextBox x:Name="txtUrunFiyat" Style="{StaticResource DarkTextBox}" Width="80" Margin="8,0,0,0" Tag="Fiyat"/>
                        <ComboBox x:Name="cmbUrunKategori" Width="150" Margin="8,0,0,0" FontSize="13"
                                  Background="#2A2A4A" Foreground="White" BorderBrush="#444466"
                                  Padding="8,6" SelectionChanged="CmbUrunKategori_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="➕ Ekle" Style="{StaticResource DarkBtn}" Background="#2E7D32" Click="BtnUrunEkle_Click"/>
                        <Button Content="🗑 Sil" Style="{StaticResource DarkBtn}" Background="#C62828" Click="BtnUrunSil_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- SALON AYARLARI TAB -->
            <TabItem Header="🏠 Salon Ayarları">
                <StackPanel Margin="24">
                    <TextBlock Text="Salon Adı:" Foreground="#8899AA" Margin="0,0,0,4" FontSize="13"/>
                    <TextBox x:Name="txtSalonAdi" Style="{StaticResource DarkTextBox}"/>

                    <TextBlock Text="Telefon:" Foreground="#8899AA" Margin="0,8,0,4" FontSize="13"/>
                    <TextBox x:Name="txtTelefon" Style="{StaticResource DarkTextBox}"/>

                    <TextBlock Text="Adres:" Foreground="#8899AA" Margin="0,8,0,4" FontSize="13"/>
                    <TextBox x:Name="txtAdres" Style="{StaticResource DarkTextBox}" TextWrapping="Wrap" Height="60"/>

                    <TextBlock Text="Saatlik Ücret (₺):" Foreground="#8899AA" Margin="0,8,0,4" FontSize="13"/>
                    <TextBox x:Name="txtSaatlikUcret" Style="{StaticResource DarkTextBox}"/>

                    <Button Content="💾 Kaydet" Style="{StaticResource DarkBtn}" Background="#2E7D32" 
                            Width="120" Click="BtnAyarKaydet_Click" Margin="0,16,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
