<UserControl x:Class="ServerApplication.Views.MasaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="200" Height="150" Margin="10">
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Manuel Başlat" Click="Menu_ManuelBaslat_Click" />
            <MenuItem Header="Manuel Ürün Ekle" Click="Menu_ManuelUrunEkle_Click" />
            <MenuItem Header="Manuel Bitir" Click="Menu_ManuelBitir_Click" />
        </ContextMenu>
    </UserControl.ContextMenu>
    <Border BorderBrush="{Binding BorderColor, FallbackValue=Gray}" BorderThickness="3" CornerRadius="8" Background="#F0F0F0">
        <StackPanel Margin="10">
            <TextBlock Text="{Binding MasaNo, FallbackValue='Masa 1'}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding DurumText, FallbackValue='Boş'}" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            <TextBlock Text="{Binding ToplamBorc, StringFormat='₺ {0:N2}', FallbackValue='₺ 0.00'}" FontSize="18" Foreground="DarkGreen" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            <TextBlock Text="{Binding GecenSureText, FallbackValue='00:00'}" FontSize="14" Foreground="DarkRed" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
