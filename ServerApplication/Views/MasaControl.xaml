<UserControl x:Class="ServerApplication.Views.MasaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="220" d:DesignWidth="320">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Kategoriye Göre Renk Atama -->
        <Style x:Key="StatusIndicator" TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Durum}" Value="Bos">
                    <Setter Property="Background" Value="#238636"/> <!-- Yeşil -->
                </DataTrigger>
                <DataTrigger Binding="{Binding Durum}" Value="Aktif">
                    <Setter Property="Background" Value="#F85149"/> <!-- Kırmızı -->
                </DataTrigger>
                <DataTrigger Binding="{Binding Durum}" Value="SiparisBekliyor">
                    <Setter Property="Background" Value="#D29922"/> <!-- Turuncu -->
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Durum bilgi metin rengi -->
        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Durum}" Value="Bos">
                    <Setter Property="Foreground" Value="#238636"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Durum}" Value="Aktif">
                    <Setter Property="Foreground" Value="#F85149"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Durum}" Value="SiparisBekliyor">
                    <Setter Property="Foreground" Value="#D29922"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Minimalist Card Border -->
        <Border x:Name="CardBorder" Background="#161B22" 
                BorderBrush="#30363D" BorderThickness="1" CornerRadius="12">
            <Border.ContextMenu>
                <ContextMenu x:Name="ctxMenu" Opened="ContextMenu_Opened">
                    <MenuItem x:Name="mnuBaslat" Header="▶ Masayı Başlat" Click="Menu_ManuelBaslat_Click" />
                    <MenuItem x:Name="mnuUrunEkle" Header="🍕 Ürün Ekle" Click="Menu_ManuelUrunEkle_Click" />
                    <MenuItem x:Name="mnuSiparisOnayla" Header="✅ Siparişi Onayla" Click="Menu_SiparisOnayla_Click" />
                    <Separator/>
                    <MenuItem x:Name="mnuHesapKes" Header="💰 Hesap Kes" Click="Menu_ManuelBitir_Click" Foreground="Red" FontWeight="Bold"/>
                </ContextMenu>
            </Border.ContextMenu>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Center Info -->
                    <RowDefinition Height="Auto"/> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Masa Başlığı ve Durum Işığı + Bilgi Metni -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="MASA" FontSize="14" Foreground="#8B949E" VerticalAlignment="Bottom" Margin="0,0,8,4"/>
                        <TextBlock Text="{Binding MasaNo}" FontSize="32" FontWeight="Black" Foreground="White" VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <!-- Durum ışığı + bilgi metni -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5,0,0">
                        <TextBlock Text="{Binding DurumBilgiText}" Style="{StaticResource StatusText}" Margin="0,0,8,0"/>
                        <Border Width="14" Height="14" CornerRadius="7" 
                                Style="{StaticResource StatusIndicator}">
                            <Border.Effect>
                                <DropShadowEffect Color="White" BlurRadius="4" Opacity="0.3" ShadowDepth="0"/>
                            </Border.Effect>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Orta Alan: Süre ve Sipariş Bilgisi -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding GecenSureText}" FontSize="24" FontWeight="SemiBold" 
                               Foreground="#C9D1D9" HorizontalAlignment="Center"/>
                    <StackPanel x:Name="pnlOrders" HorizontalAlignment="Center" Margin="0,5"
                                Visibility="{Binding HasPendingOrder, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🔔" FontSize="18" Margin="0,0,5,0">
                                <TextBlock.ToolTip>
                                    <ToolTip Content="Onay bekleyen sipariş var!" Background="#1a1a1a" Foreground="White" BorderThickness="0"/>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock Text="Yeni Sipariş" FontSize="16" FontWeight="SemiBold" Foreground="#D29922"/>
                        </StackPanel>
                        <!-- Sipariş detayı -->
                        <TextBlock Text="{Binding BekleyenSiparis}" FontSize="13" Foreground="#8B949E" 
                                   HorizontalAlignment="Center" Margin="0,3,0,0" TextWrapping="Wrap" 
                                   TextAlignment="Center" MaxWidth="250"/>
                    </StackPanel>
                </StackPanel>

                <!-- Alt Bar: Toplam Tutar -->
                <Border Grid.Row="2" Background="#0D1117" CornerRadius="8" Padding="15,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TOPLAM" FontSize="14" FontWeight="Bold" Foreground="#8B949E" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ToplamBorc, StringFormat={}{0:N2} ₺}" 
                                   FontSize="22" FontWeight="Black" Foreground="#58A6FF"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
