<Window x:Class="ServerApplication.Views.Client.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ServerApplication.ViewModels"
        Title="Masa Ekranı" 
        WindowState="Maximized" WindowStyle="None"
        Background="#0D1117">

    <Window.DataContext>
        <vm:ClientViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Modern minimalist style for scoreboard items -->
        <Style x:Key="ScoreLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ScoreValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HighRunBadge" TargetType="Border">
            <Setter Property="Background" Value="#1C2128"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CafeButton" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> <!-- Left Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Main Area -->
        </Grid.ColumnDefinitions>

        <!-- ==================== LEFT SIDEBAR ==================== -->
        <Border Grid.Column="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Logo/MasaId -->
                    <RowDefinition Height="Auto"/> <!-- Salon Info -->
                    <RowDefinition Height="*"/>    <!-- Campaigns -->
                    <RowDefinition Height="Auto"/> <!-- Cafe Button -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
                    <TextBlock Text="MASA" FontSize="20" Foreground="#8B949E" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding MasaId}" FontSize="96" FontWeight="Black" Foreground="#58A6FF" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,30">
                    <TextBlock Text="{Binding SalonAdi}" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Telefon}" FontSize="18" Foreground="#8B949E" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Adres}" FontSize="15" Foreground="#8B949E" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Kampanya Alanı -->
                <Border Grid.Row="2" Background="#0D1117" CornerRadius="15" Margin="0,0,0,20" BorderBrush="#30363D" BorderThickness="1" ClipToBounds="True">
                    <Grid>
                        <!-- Kampanya resim alanı statik veya ViewModel'den gelebilir. Mevcut VM'de ImageUrl yok, Header/Aciklama var. -->
                        <Border Background="#1C2128" />
                        <StackPanel VerticalAlignment="Center" Margin="20">
                            <TextBlock Text="{Binding KampanyaBaslik}" Foreground="#FFD700" FontSize="22" FontWeight="Black" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding KampanyaAciklama}" Foreground="White" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            <TextBlock Text="{Binding KampanyaFiyat}" Foreground="#58A6FF" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button Grid.Row="3" Style="{StaticResource CafeButton}" Content="☕ KAFE / MENÜ" Command="{Binding ToggleCafePopupCommand}"/>
            </Grid>
        </Border>

        <!-- ==================== MAIN AREA ==================== -->
        <Grid Grid.Column="1" Margin="40">
            <!-- Scoreboard Grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Player A -->
                <Border Grid.Column="0" Background="#161B22" CornerRadius="24" Margin="15" BorderBrush="#30363D" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Background="#21262D" CornerRadius="24,24,0,0" Padding="20">
                            <TextBlock Text="{Binding DisplayPlayerAName}" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Grid.Row="1" Text="{Binding PlayerAScore}" FontSize="240" FontWeight="Black" Foreground="#58A6FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <StackPanel Grid.Row="2" Margin="30,0,30,30">
                            <TextBlock Text="{Binding PlayerAAverageText}" FontSize="26" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="EN YÜKSEK" Style="{StaticResource ScoreLabel}"/>
                                    <Border Style="{StaticResource HighRunBadge}">
                                        <TextBlock Text="{Binding PlayerAHighRun1}" Style="{StaticResource ScoreValue}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="2. YÜKSEK" Style="{StaticResource ScoreLabel}"/>
                                    <Border Style="{StaticResource HighRunBadge}">
                                        <TextBlock Text="{Binding PlayerAHighRun2}" Style="{StaticResource ScoreValue}"/>
                                    </Border>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- VS / TUR -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="30,0">
                    <TextBlock Text="TUR" FontSize="26" Foreground="#8B949E" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TurCount}" FontSize="72" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                    <Border Background="#238636" CornerRadius="30" Width="100" Height="60" Margin="0,30">
                        <TextBlock Text="VS" FontSize="32" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Player B -->
                <Border Grid.Column="2" Background="#161B22" CornerRadius="24" Margin="15" BorderBrush="#30363D" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Background="#21262D" CornerRadius="24,24,0,0" Padding="20">
                            <TextBlock Text="{Binding DisplayPlayerBName}" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Grid.Row="1" Text="{Binding PlayerBScore}" FontSize="240" FontWeight="Black" Foreground="#F85149" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <StackPanel Grid.Row="2" Margin="30,0,30,30">
                            <TextBlock Text="{Binding PlayerBAverageText}" FontSize="26" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="EN YÜKSEK" Style="{StaticResource ScoreLabel}"/>
                                    <Border Style="{StaticResource HighRunBadge}">
                                        <TextBlock Text="{Binding PlayerBHighRun1}" Style="{StaticResource ScoreValue}"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="10,0">
                                    <TextBlock Text="2. YÜKSEK" Style="{StaticResource ScoreLabel}"/>
                                    <Border Style="{StaticResource HighRunBadge}">
                                        <TextBlock Text="{Binding PlayerBHighRun2}" Style="{StaticResource ScoreValue}"/>
                                    </Border>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- CAFE POPUP -->
        <Border Grid.ColumnSpan="2" Background="#99000000" 
                Visibility="{Binding IsCafePopupVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="#161B22" Width="1000" Height="800" CornerRadius="24" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#30363D" BorderThickness="1">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,30">
                        <TextBlock Text="KAFE MENÜ" FontSize="40" FontWeight="Black" Foreground="White"/>
                        <Button HorizontalAlignment="Right" Content="✕" FontSize="32" Foreground="#8B949E" Background="Transparent" BorderThickness="0" Command="{Binding CloseCafePopupCommand}" Cursor="Hand"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MenuItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#21262D" Margin="0,0,0,15" CornerRadius="15" Padding="25">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Ad}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding Fiyat, StringFormat={}{0:N2} ₺}" FontSize="20" Foreground="#8B949E" Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0">
                                                <Button Content="-" Width="56" Height="56" FontSize="28" Background="#30363D" Foreground="White" BorderThickness="0" Command="{Binding ArttirCommand}" Margin="0,0,20,0" Visibility="Collapsed"/> <!-- Command hatası düzeltilecek -->
                                                <!-- ViewModel'de UrunViewModel ArttirCommand ve AzaltCommand var. Bindings: -->
                                                <Button Content="-" Width="56" Height="56" FontSize="28" Background="#30363D" Foreground="White" BorderThickness="0" Command="{Binding AzaltCommand}" Margin="0,0,20,0"/>
                                                <TextBlock Text="{Binding Adet}" FontSize="36" FontWeight="Black" Foreground="#58A6FF" MinWidth="40" TextAlignment="Center" VerticalAlignment="Center"/>
                                                <Button Content="+" Width="56" Height="56" FontSize="28" Background="#238636" Foreground="White" BorderThickness="0" Command="{Binding ArttirCommand}" Margin="20,0,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" Text="ONAYLI" VerticalAlignment="Center" FontSize="16" Foreground="#238636" FontWeight="Bold"
                                                       Visibility="{Binding OnaylananAdet, Converter={StaticResource IntToVis}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="SİPARİŞİ TAMAMLA" Style="{StaticResource CafeButton}" Height="80" Command="{Binding SiparisGonderCommand}" Margin="0,30,0,0"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
