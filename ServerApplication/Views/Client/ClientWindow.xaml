<Window x:Class="ServerApplication.Views.Client.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ServerApplication.ViewModels"
        xmlns:conv="clr-namespace:ServerApplication.Converters"
        Title="Masa Ekranı" 
        WindowState="Maximized" WindowStyle="None"
        Background="#0D1117"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.DataContext>
        <vm:ClientViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:IntToVisibilityConverter x:Key="IntToVis"/>

        <!-- Modern minimalist style for scoreboard items -->
        <Style x:Key="ScoreLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ScoreValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HighRunBadge" TargetType="Border">
            <Setter Property="Background" Value="#1C2128"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CafeButton" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Score +/- Buttons -->
        <Style x:Key="ScoreBtn" TargetType="Button">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pre-match field style -->
        <Style x:Key="PreMatchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- Pre-match small button -->
        <Style x:Key="PreMatchSmallBtn" TargetType="Button">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Handikap Oyuncu Seçim Butonu -->
        <Style x:Key="HandikapSelectBtn" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> <!-- Left Sidebar -->
            <ColumnDefinition Width="*"/>   <!-- Main Area -->
        </Grid.ColumnDefinitions>

        <!-- ==================== LEFT SIDEBAR ==================== -->
        <Border Grid.Column="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,1,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Logo/MasaId -->
                    <RowDefinition Height="Auto"/> <!-- Salon Info -->
                    <RowDefinition Height="*"/>    <!-- Campaigns -->
                    <RowDefinition Height="Auto"/> <!-- Cafe Button -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
                    <TextBlock Text="MASA" FontSize="20" Foreground="#8B949E" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding MasaId}" FontSize="96" FontWeight="Black" Foreground="#58A6FF" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,30">
                    <TextBlock Text="{Binding SalonAdi}" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Telefon}" FontSize="18" Foreground="#8B949E" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Adres}" FontSize="15" Foreground="#8B949E" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Kampanya Alanı -->
                <Border Grid.Row="2" Background="#0D1117" CornerRadius="15" Margin="0,0,0,20" BorderBrush="#30363D" BorderThickness="1" ClipToBounds="True">
                    <Grid>
                        <Border Background="#1C2128" />
                        <StackPanel VerticalAlignment="Center" Margin="20">
                            <TextBlock Text="{Binding KampanyaBaslik}" Foreground="#FFD700" FontSize="22" FontWeight="Black" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding KampanyaAciklama}" Foreground="White" FontSize="16" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            <TextBlock Text="{Binding KampanyaFiyat}" Foreground="#58A6FF" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button Grid.Row="3" Style="{StaticResource CafeButton}" Content="☕ KAFE / MENÜ" Command="{Binding ToggleCafePopupCommand}"/>
            </Grid>
        </Border>

        <!-- ==================== MAIN AREA ==================== -->
        <Grid Grid.Column="1" Margin="40">

            <!-- ========== PRE-MATCH SCREEN ========== -->
            <Grid Visibility="{Binding IsMatchStarted, Converter={StaticResource InverseBoolToVis}}">
                <Border Background="#161B22" CornerRadius="24" BorderBrush="#30363D" BorderThickness="1" 
                        Padding="60" MaxWidth="900" MaxHeight="750"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <!-- Başlık -->
                        <TextBlock Text="🎱 YENİ MAÇ" FontSize="42" FontWeight="Black" Foreground="White" 
                                   HorizontalAlignment="Center" Margin="0,0,0,40"/>

                        <!-- Hedef Sayı -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                            <TextBlock Text="HEDEF SAYI" FontSize="18" Foreground="#8B949E" 
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource PreMatchSmallBtn}" Content="−" 
                                        Background="#30363D" Command="{Binding HedefSayiDownCommand}"/>
                                <Border Background="#21262D" CornerRadius="12" MinWidth="120" Margin="15,0" 
                                        BorderBrush="#30363D" BorderThickness="1">
                                    <TextBlock Text="{Binding HedefSayi}" FontSize="48" FontWeight="Black" 
                                               Foreground="#58A6FF" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" Margin="20,5"/>
                                </Border>
                                <Button Style="{StaticResource PreMatchSmallBtn}" Content="+" 
                                        Background="#238636" Command="{Binding HedefSayiUpCommand}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Oyuncu İsimleri -->
                        <Grid Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="OYUNCU A" FontSize="16" Foreground="#58A6FF" 
                                           Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                <TextBox Style="{StaticResource PreMatchTextBox}" 
                                         Text="{Binding PlayerAName, UpdateSourceTrigger=PropertyChanged}" 
                                         TextAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="VS" FontSize="20" FontWeight="Bold" 
                                       Foreground="#8B949E" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="OYUNCU B" FontSize="16" Foreground="#F85149" 
                                           Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                <TextBox Style="{StaticResource PreMatchTextBox}" 
                                         Text="{Binding PlayerBName, UpdateSourceTrigger=PropertyChanged}" 
                                         TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Handikap -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,35">
                            <TextBlock Text="HANDİKAP" FontSize="18" Foreground="#8B949E" 
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <!-- Player A seç -->
                                <Button Content="Oyuncu A" Command="{Binding SelectHandikapACommand}"
                                        Margin="0,0,10,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource HandikapSelectBtn}">
                                            <Setter Property="Background" Value="#21262D"/>
                                            <Setter Property="BorderBrush" Value="#30363D"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHandikapA}" Value="True">
                                                    <Setter Property="Background" Value="#1A3A5C"/>
                                                    <Setter Property="BorderBrush" Value="#58A6FF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <!-- Player B seç -->
                                <Button Content="Oyuncu B" Command="{Binding SelectHandikapBCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource HandikapSelectBtn}">
                                            <Setter Property="Background" Value="#21262D"/>
                                            <Setter Property="BorderBrush" Value="#30363D"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHandikapB}" Value="True">
                                                    <Setter Property="Background" Value="#3A1A1A"/>
                                                    <Setter Property="BorderBrush" Value="#F85149"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                            <!-- Handikap Değer -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource PreMatchSmallBtn}" Content="−" 
                                        Background="#30363D" Command="{Binding HandikapDownCommand}" 
                                        Width="42" Height="42"/>
                                <Border Background="#21262D" CornerRadius="10" MinWidth="80" Margin="10,0" 
                                        BorderBrush="#30363D" BorderThickness="1">
                                    <TextBlock Text="{Binding HandikapDeger}" FontSize="32" FontWeight="Black" 
                                               Foreground="#D29922" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" Margin="12,3"/>
                                </Border>
                                <Button Style="{StaticResource PreMatchSmallBtn}" Content="+" 
                                        Background="#D29922" Command="{Binding HandikapUpCommand}" 
                                        Width="42" Height="42"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Başlat Butonu -->
                        <Button Style="{StaticResource CafeButton}" Content="🎯 MAÇI BAŞLAT" 
                                Command="{Binding StartMatchCommand}" FontSize="28" 
                                Height="70" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ========== SCOREBOARD (Post-match) ========== -->
            <Grid Visibility="{Binding IsMatchStarted, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Scoreboard Grid -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Player A -->
                    <Border Grid.Column="0" Background="#161B22" CornerRadius="24" Margin="15" BorderBrush="#30363D" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Border Background="#21262D" CornerRadius="24,24,0,0" Padding="20">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Turn Ball for Player A -->
                                    <Ellipse Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"
                                             Visibility="{Binding IsPlayerATurn, Converter={StaticResource BoolToVis}}">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#58A6FF" Offset="0"/>
                                                <GradientStop Color="#1F6FEB" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#58A6FF" BlurRadius="10" Opacity="0.7" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="{Binding DisplayPlayerAName}" FontSize="32" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>

                            <!-- Score with +/- buttons -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Style="{StaticResource ScoreBtn}" Content="−" Background="#30363D" 
                                        Command="{Binding PlayerAScoreDownCommand}" Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding PlayerAScore}" FontSize="200" FontWeight="Black" 
                                           Foreground="#58A6FF" VerticalAlignment="Center"/>
                                <Button Style="{StaticResource ScoreBtn}" Content="+" Background="#238636" 
                                        Command="{Binding PlayerAScoreUpCommand}" Margin="15,0,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="30,0,30,30">
                                <TextBlock Text="{Binding PlayerAAverageText}" FontSize="26" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="10,0">
                                        <TextBlock Text="EN YÜKSEK" Style="{StaticResource ScoreLabel}"/>
                                        <Border Style="{StaticResource HighRunBadge}">
                                            <TextBlock Text="{Binding PlayerAHighRun1}" Style="{StaticResource ScoreValue}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Margin="10,0">
                                        <TextBlock Text="2. YÜKSEK" Style="{StaticResource ScoreLabel}"/>
                                        <Border Style="{StaticResource HighRunBadge}">
                                            <TextBlock Text="{Binding PlayerAHighRun2}" Style="{StaticResource ScoreValue}"/>
                                        </Border>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- VS / TUR -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="30,0">
                        <TextBlock Text="TUR" FontSize="26" Foreground="#8B949E" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TurCount}" FontSize="72" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                        <Border Background="#238636" CornerRadius="30" Width="100" Height="60" Margin="0,30">
                            <TextBlock Text="VS" FontSize="32" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Süre -->
                        <TextBlock Text="{Binding KalanSureText}" FontSize="20" Foreground="#8B949E" 
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>

                    <!-- Player B -->
                    <Border Grid.Column="2" Background="#161B22" CornerRadius="24" Margin="15" BorderBrush="#30363D" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Background="#21262D" CornerRadius="24,24,0,0" Padding="20">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayPlayerBName}" FontSize="32" FontWeight="Bold" Foreground="White"/>
                                    <!-- Turn Ball for Player B -->
                                    <Ellipse Width="20" Height="20" Margin="12,0,0,0" VerticalAlignment="Center"
                                             Visibility="{Binding IsPlayerBTurn, Converter={StaticResource BoolToVis}}">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#F85149" Offset="0"/>
                                                <GradientStop Color="#DA3633" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#F85149" BlurRadius="10" Opacity="0.7" ShadowDepth="0"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </StackPanel>
                            </Border>

                            <!-- Score with +/- buttons -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Style="{StaticResource ScoreBtn}" Content="−" Background="#30363D" 
                                        Command="{Binding PlayerBScoreDownCommand}" Margin="0,0,15,0"/>
                                <TextBlock Text="{Binding PlayerBScore}" FontSize="200" FontWeight="Black" 
                                           Foreground="#F85149" VerticalAlignment="Center"/>
                                <Button Style="{StaticResource ScoreBtn}" Content="+" Background="#238636" 
                                        Command="{Binding PlayerBScoreUpCommand}" Margin="15,0,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="30,0,30,30">
                                <TextBlock Text="{Binding PlayerBAverageText}" FontSize="26" Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="10,0">
                                        <TextBlock Text="EN YÜKSEK" Style="{StaticResource ScoreLabel}"/>
                                        <Border Style="{StaticResource HighRunBadge}">
                                            <TextBlock Text="{Binding PlayerBHighRun1}" Style="{StaticResource ScoreValue}"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Margin="10,0">
                                        <TextBlock Text="2. YÜKSEK" Style="{StaticResource ScoreLabel}"/>
                                        <Border Style="{StaticResource HighRunBadge}">
                                            <TextBlock Text="{Binding PlayerBHighRun2}" Style="{StaticResource ScoreValue}"/>
                                        </Border>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Reset Button -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button Style="{StaticResource CafeButton}" Content="🔄 MAÇI SIFIRLA" 
                            Command="{Binding ResetMatchCommand}" Background="#D73A49" 
                            FontSize="18" Padding="30,12"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ==================== CAFE POPUP ==================== -->
        <Border Grid.ColumnSpan="2" Background="#99000000" 
                Visibility="{Binding IsCafePopupVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="#161B22" Width="1000" Height="800" CornerRadius="24" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#30363D" BorderThickness="1">
                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,30">
                        <TextBlock Text="KAFE MENÜ" FontSize="40" FontWeight="Black" Foreground="White"/>
                        <Button HorizontalAlignment="Right" Content="✕" FontSize="32" Foreground="#8B949E" Background="Transparent" BorderThickness="0" Command="{Binding CloseCafePopupCommand}" Cursor="Hand"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MenuItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#21262D" Margin="0,0,0,15" CornerRadius="15" Padding="25">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Ad}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding Fiyat, StringFormat={}{0:N2} ₺}" FontSize="20" Foreground="#8B949E" Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,30,0">
                                                <Button Content="-" Width="56" Height="56" FontSize="28" Background="#30363D" Foreground="White" BorderThickness="0" Command="{Binding AzaltCommand}" Margin="0,0,20,0"/>
                                                <TextBlock Text="{Binding Adet}" FontSize="36" FontWeight="Black" Foreground="#58A6FF" MinWidth="40" TextAlignment="Center" VerticalAlignment="Center"/>
                                                <Button Content="+" Width="56" Height="56" FontSize="28" Background="#238636" Foreground="White" BorderThickness="0" Command="{Binding ArttirCommand}" Margin="20,0,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2" Text="ONAYLI" VerticalAlignment="Center" FontSize="16" Foreground="#238636" FontWeight="Bold"
                                                       Visibility="{Binding OnaylananAdet, Converter={StaticResource IntToVis}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="2" Content="SİPARİŞİ TAMAMLA" Style="{StaticResource CafeButton}" Height="80" Command="{Binding SiparisGonderCommand}" Margin="0,30,0,0"/>
                </Grid>
            </Border>
        </Border>

        <!-- ==================== ADMIN PANEL OVERLAY ==================== -->
        <Border Grid.ColumnSpan="2" Background="#CC000000" 
                Visibility="{Binding IsAdminPanelVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="#161B22" Width="450" Height="280" CornerRadius="24" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" 
                    BorderBrush="#30363D" BorderThickness="1">
                <StackPanel Margin="40" VerticalAlignment="Center">
                    <TextBlock Text="🔒 Çıkış Şifresi" FontSize="28" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="Çıkmak için admin şifresini girin:" FontSize="16" 
                               Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <PasswordBox x:Name="txtAdminPassword" FontSize="20" Padding="12,10" 
                                 Background="#21262D" Foreground="White" BorderBrush="#30363D" 
                                 MaxLength="20" HorizontalAlignment="Stretch"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="Çıkış Yap" FontSize="18" FontWeight="Bold" Foreground="White" 
                                Background="#238636" Padding="25,12" Cursor="Hand" 
                                Click="BtnAdminExit_Click" Margin="0,0,15,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                          Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="İptal" FontSize="18" FontWeight="Bold" Foreground="White" 
                                Background="#30363D" Padding="25,12" Cursor="Hand" 
                                Command="{Binding CancelAdminPanelCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                          Margin="{TemplateBinding Padding}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
