<Window x:Class="ServerApplication.Views.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hesap Kesim" Height="350" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="{Binding MasaNo, StringFormat='{}Hesap: {0}'}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Ara Toplam:" FontSize="16" />
            <TextBlock Grid.Column="1" Text="{Binding AraToplam, StringFormat='₺ {0:N2}'}" FontSize="16" FontWeight="Bold"/>
        </Grid>
        
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Yönetici Şifresi:" VerticalAlignment="Center"/>
            <PasswordBox Grid.Column="1" x:Name="txtPassword" PasswordChanged="txtPassword_PasswordChanged" />
        </Grid>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="İndirim Tutarı:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" Text="{Binding Indirim, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsDiscountEnabled}" />
        </Grid>
        
        <Border BorderBrush="Gray" BorderThickness="0,1,0,0" Margin="0,10,0,10" />
        
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="ÖDENECEK TUTAR:" FontSize="16" FontWeight="Bold" Foreground="DarkRed"/>
            <TextBlock Grid.Column="1" Text="{Binding ToplamTutar, StringFormat='₺ {0:N2}'}" FontSize="20" FontWeight="Bold" Foreground="DarkRed"/>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Nakit Ödeme" Command="{Binding OdemeYapCommand}" CommandParameter="Nakit" Click="Payment_Click" Width="100" Height="40" Margin="0,0,10,0" Background="#4CAF50" Foreground="White" BorderThickness="0"/>
            <Button Content="Kredi Kartı" Command="{Binding OdemeYapCommand}" CommandParameter="Kredi Karti" Click="Payment_Click" Width="100" Height="40" Background="#2196F3" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>
