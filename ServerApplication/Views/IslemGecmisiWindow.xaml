<Window x:Class="ServerApplication.Views.IslemGecmisiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 İşlem Geçmişi" Height="550" Width="800"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#1A1A2E">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📊 Kesilen Hesaplar" FontSize="20" FontWeight="Bold" 
                   Foreground="White" Margin="0,0,0,12"/>

        <!-- Filtre -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="btnBugun" Content="Bugün" Click="Filtre_Click" Tag="Bugun"
                    Background="#2E7D32" Foreground="White" Padding="14,6" FontSize="13"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#388E3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button x:Name="btnDun" Content="Dün" Click="Filtre_Click" Tag="Dun"
                    Background="#2A2A4A" Foreground="White" Padding="14,6" FontSize="13"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button x:Name="btnHafta" Content="Bu Hafta" Click="Filtre_Click" Tag="Hafta"
                    Background="#2A2A4A" Foreground="White" Padding="14,6" FontSize="13"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button x:Name="btnTumu" Content="Tümü" Click="Filtre_Click" Tag="Tumu"
                    Background="#2A2A4A" Foreground="White" Padding="14,6" FontSize="13"
                    BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- İşlem Listesi -->
        <ListView x:Name="lstIslemler" Grid.Row="2" Background="#2A2A4A" Foreground="White" 
                  BorderThickness="0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Masa" Width="70" DisplayMemberBinding="{Binding MasaNo}"/>
                    <GridViewColumn Header="Başlangıç" Width="80" DisplayMemberBinding="{Binding Baslangic, StringFormat='HH:mm'}"/>
                    <GridViewColumn Header="Bitiş" Width="80" DisplayMemberBinding="{Binding Bitis, StringFormat='HH:mm'}"/>
                    <GridViewColumn Header="Süre ₺" Width="80" DisplayMemberBinding="{Binding UcretSure, StringFormat='₺{0:N0}'}"/>
                    <GridViewColumn Header="Sipariş ₺" Width="80" DisplayMemberBinding="{Binding UcretSiparis, StringFormat='₺{0:N0}'}"/>
                    <GridViewColumn Header="İndirim" Width="80" DisplayMemberBinding="{Binding Indirim, StringFormat='₺{0:N0}'}"/>
                    <GridViewColumn Header="Toplam" Width="90" DisplayMemberBinding="{Binding ToplamTutar, StringFormat='₺{0:N0}'}"/>
                    <GridViewColumn Header="Ödeme" Width="80" DisplayMemberBinding="{Binding OdemeTipi}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- İstatistikler -->
        <Border Grid.Row="3" Background="#16213E" CornerRadius="8" Padding="16,10" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="İşlem Sayısı" FontSize="11" Foreground="#8899AA" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtIslemSayisi" Text="0" FontSize="20" FontWeight="Bold" 
                               Foreground="#00E5FF" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="Nakit ₺" FontSize="11" Foreground="#8899AA" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtNakit" Text="₺0" FontSize="20" FontWeight="Bold" 
                               Foreground="#00E676" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="Kart ₺" FontSize="11" Foreground="#8899AA" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtKart" Text="₺0" FontSize="20" FontWeight="Bold" 
                               Foreground="#448AFF" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="Toplam ₺" FontSize="11" Foreground="#8899AA" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtToplam" Text="₺0" FontSize="20" FontWeight="Bold" 
                               Foreground="#FFD700" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Button Grid.Row="4" Content="Kapat" Width="120" Height="38" FontSize="14"
                Background="#2A2A4A" Foreground="White" BorderThickness="0" Cursor="Hand"
                Click="BtnKapat_Click" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3A3A6A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
