<Window x:Class="ServerApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ServerApplication.Views"
        Title="Bilardo Salonu — Kasa" 
        WindowState="Maximized" WindowStyle="None"
        Background="#1A1A2E"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Window.Resources>
        <!-- Dark theme button style -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A4A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4A4A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== HEADER BAR ==================== -->
        <Border Grid.Row="0" Background="#16213E" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sol: Saat + Tarih -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SaatText}" FontSize="32" FontWeight="Bold" Foreground="#00E5FF" 
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TarihText}" FontSize="14" Foreground="#8899AA" 
                               Margin="16,0,0,0" VerticalAlignment="Center"/>
                    <Border Background="#2A2A4A" CornerRadius="8" Padding="12,6" Margin="24,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SalonAdi}" FontSize="14" FontWeight="SemiBold" Foreground="#E0E0FF"/>
                    </Border>
                    <TextBlock Text="{Binding Telefon}" FontSize="12" Foreground="#7788AA" 
                               Margin="16,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Sağ: Butonlar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔔 Bildirimler" Style="{StaticResource DarkButton}" Margin="0,0,8,0"
                            Visibility="{Binding HasNotification, Converter={StaticResource BoolToVis}}"
                            Command="{Binding SiparisleriGosterCommand}"/>
                    <Button Content="📊 Geçmiş" Style="{StaticResource DarkButton}" Margin="0,0,8,0"
                            Command="{Binding IslemGecmisiGosterCommand}"/>
                    <Button Content="📋 Menü" Style="{StaticResource DarkButton}" Margin="0,0,8,0"
                            Command="{Binding MenuGosterCommand}"/>
                    <Button Content="⚙ Ayarlar" Style="{StaticResource DarkButton}" Margin="0,0,8,0"
                            Command="{Binding AdminPanelCommand}"/>
                    <Button Content="🔄 Yenile" Style="{StaticResource DarkButton}" Margin="0,0,8,0"
                            Command="{Binding RefreshCommand}"/>
                    <Button Content="🚪 Çıkış" Style="{StaticResource DarkButton}" Click="BtnMainMenu_Click"
                            Background="#4A1A1A"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== MASA GRID (3x3) ==================== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Margin="16,16,16,0">
            <ItemsControl ItemsSource="{Binding Masalar}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:MasaControl Margin="8"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ==================== ALTTA KAMPANYA BANNER ==================== -->
        <Border Grid.Row="2" Background="#0F3460" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🎯 KAMPANYALAR:" FontSize="14" FontWeight="Bold" 
                           Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="1" Text="{Binding KampanyaBannerText}" FontSize="13" 
                           Foreground="#E0E0FF" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- ==================== DEMO BADGE ==================== -->
        <Border Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0"
                Background="#FF5722" CornerRadius="0,0,8,8" Padding="16,4"
                Visibility="{Binding IsDemoMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="🎮 DEMO MODU — ESC ile çık" FontSize="12" FontWeight="Bold" Foreground="White"/>
        </Border>
    </Grid>
</Window>
