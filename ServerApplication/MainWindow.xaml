<Window x:Class="ServerApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ServerApplication.Views"
        Title="Ticari Otomasyon Dashboard" Height="600" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="10" Orientation="Horizontal">
            <TextBlock Text="Masa Yönetimi" FontSize="28" FontWeight="Bold"/>
            <Button Content="Masaları Yenile" Command="{Binding RefreshCommand}" Margin="20,0,0,0" Padding="10,5"/>
            <Button Content="Ana Menüye (Kuruluma) Dön" Click="BtnMainMenu_Click" Margin="20,0,0,0" Padding="10,5" Background="#FF4F4F" Foreground="White"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Masalar}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:MasaControl />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
